{
  "name": "tree-llm",
  "version": "1.0.0",
  "description": "Tree-based LLM agent executor with tool use, loop detection, and context compression",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "example": "ts-node examples/example.ts",
    "test": "jest",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\""
  },
  "keywords": [
    "llm",
    "agent",
    "openai",
    "gemini",
    "ollama",
    "tool-use",
    "tree"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.1",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "dotenv": "^17.4.2",
    "eslint": "^10.4.0",
    "jest": "^30.4.2",
    "prettier": "^3.8.3",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@e2b/code-interpreter": "^2.5.0",
    "docx": "^9.6.1",
    "openai": "^6.39.0"
  },
  "engines": {
    "node": ">=18"
  }
}
